// Nuxwell Prisma Schema
// Wellness Fitness Platform Database
// Note: Profile table is linked to Supabase auth.users via userId field.
// Since Supabase auth is managed internally, we use a logical relation
// (userId maps to auth.users.id) rather than a database foreign key.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Prisma Seed Configuration
// Run with: npx prisma db seed
// Or: npm run prisma:seed


// User Role Enum
enum Role {
  ADMIN
  TRAINER
  MEMBER
  USER
}

// User Profile - extends Supabase Auth
// The userId field directly corresponds to Supabase auth.users.id
// This is the PRIMARY KEY since each profile is 1:1 with a Supabase user
model Profile {
  userId       String    @id // Primary key = Supabase auth.users.id
  email        String    @unique
  fullName     String?
  avatarUrl    String?
  weight       Float?
  height       Float?
  fitnessGoal  String?   // e.g., "weight_loss", "muscle_gain", "maintenance"
  role         Role      @default(USER)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  workouts     Workout[]
  meals        Meal[]
  progress     Progress[]
}

// Workout Sessions
model Workout {
  id              String    @id @default(cuid())
  userId          String    // FK to Profile.userId (Supabase auth.users.id)
  profile         Profile   @relation(fields: [userId], references: [userId], onDelete: Cascade)
  name            String
  type            String    // cardio, strength, flexibility, hiit, yoga
  durationMinutes Int
  caloriesBurned  Int?
  exercises       Json?     // Array of exercise objects
  completedAt     DateTime  @default(now())
  createdAt       DateTime  @default(now())

  @@index([userId])
}

// Meal Logging
model Meal {
  id          String    @id @default(cuid())
  userId      String    // FK to Profile.userId (Supabase auth.users.id)
  profile     Profile   @relation(fields: [userId], references: [userId], onDelete: Cascade)
  name        String
  type        String    // breakfast, lunch, dinner, snack
  calories    Int
  protein     Float?
  carbs       Float?
  fats        Float?
  ingredients Json?     // Array of ingredient objects
  loggedAt    DateTime  @default(now())
  createdAt   DateTime  @default(now())

  @@index([userId])
}

// Progress Tracking
model Progress {
  id                String    @id @default(cuid())
  userId            String    // FK to Profile.userId (Supabase auth.users.id)
  profile           Profile   @relation(fields: [userId], references: [userId], onDelete: Cascade)
  weight            Float?
  bodyFatPercentage Float?
  measurements      Json?     // { chest, waist, hips, arms, thighs }
  notes             String?
  recordedAt        DateTime  @default(now())
  createdAt         DateTime  @default(now())

  @@index([userId])
}
